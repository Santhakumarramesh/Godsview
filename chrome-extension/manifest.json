{
  "manifest_version": 3,
  "name": "GodsView TradingView Bridge",
  "short_name": "GodsView",
  "description": "Capture TradingView chart context and POST signals to the GodsView MCP webhook. Renders GodsView decisions back onto the chart.",
  "version": "1.0.0",
  "permissions": ["storage", "activeTab", "scripting", "alarms"],
  "host_permissions": [
    "https://*.tradingview.com/*",
    "http://localhost/*",
    "http://127.0.0.1/*",
    "https://*/*"
  ],
  "background": {
    "service_worker": "background.js",
    "type": "module"
  },
  "content_scripts": [
    {
      "matches": [
        "https://*.tradingview.com/chart/*",
        "https://*.tradingview.com/symbols/*"
      ],
      "js": ["content.js"],
      "run_at": "document_idle"
    }
  ],
  "action": {
    "default_popup": "popup.html",
    "default_title": "GodsView Bridge",
    "default_icon": {
      "16": "icons/icon-16.png",
      "32": "icons/icon-32.png",
      "48": "icons/icon-48.png",
      "128": "icons/icon-128.png"
    }
  },
  "icons": {
    "16": "icons/icon-16.png",
    "32": "icons/icon-32.png",
    "48": "icons/icon-48.png",
    "128": "icons/icon-128.png"
  }
}
