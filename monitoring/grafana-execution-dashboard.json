{
  "dashboard": {
    "title": "GodsView Execution & Risk",
    "uid": "godsview-execution",
    "tags": ["godsview", "execution", "risk"],
    "timezone": "browser",
    "refresh": "5s",
    "time": { "from": "now-3h", "to": "now" },
    "panels": [
      {
        "title": "Order Fill Rate",
        "type": "gauge",
        "gridPos": { "h": 4, "w": 4, "x": 0, "y": 0 },
        "targets": [{ "expr": "godsview_order_fill_rate", "legendFormat": "Fill Rate" }],
        "fieldConfig": { "defaults": { "min": 0, "max": 1, "unit": "percentunit", "thresholds": { "steps": [{ "value": null, "color": "red" }, { "value": 0.8, "color": "yellow" }, { "value": 0.95, "color": "green" }] } } }
      },
      {
        "title": "Avg Slippage (bps)",
        "type": "stat",
        "gridPos": { "h": 4, "w": 4, "x": 4, "y": 0 },
        "targets": [{ "expr": "godsview_avg_slippage_bps", "legendFormat": "Slippage" }],
        "fieldConfig": { "defaults": { "unit": "none", "thresholds": { "steps": [{ "value": null, "color": "green" }, { "value": 5, "color": "yellow" }, { "value": 15, "color": "red" }] } } }
      },
      {
        "title": "Order Latency (P95)",
        "type": "stat",
        "gridPos": { "h": 4, "w": 4, "x": 8, "y": 0 },
        "targets": [{ "expr": "histogram_quantile(0.95, rate(godsview_order_latency_seconds_bucket[5m]))", "legendFormat": "P95" }],
        "fieldConfig": { "defaults": { "unit": "s", "thresholds": { "steps": [{ "value": null, "color": "green" }, { "value": 0.5, "color": "yellow" }, { "value": 2, "color": "red" }] } } }
      },
      {
        "title": "VaR 95% Portfolio",
        "type": "stat",
        "gridPos": { "h": 4, "w": 4, "x": 12, "y": 0 },
        "targets": [{ "expr": "godsview_portfolio_var_95", "legendFormat": "VaR 95%" }],
        "fieldConfig": { "defaults": { "unit": "percentunit", "thresholds": { "steps": [{ "value": null, "color": "green" }, { "value": -0.03, "color": "yellow" }, { "value": -0.05, "color": "red" }] } } }
      },
      {
        "title": "Exposure %",
        "type": "gauge",
        "gridPos": { "h": 4, "w": 4, "x": 16, "y": 0 },
        "targets": [{ "expr": "godsview_portfolio_exposure_pct", "legendFormat": "Exposure" }],
        "fieldConfig": { "defaults": { "min": 0, "max": 100, "unit": "percent", "thresholds": { "steps": [{ "value": null, "color": "green" }, { "value": 70, "color": "yellow" }, { "value": 90, "color": "red" }] } } }
      },
      {
        "title": "Margin Used %",
        "type": "gauge",
        "gridPos": { "h": 4, "w": 4, "x": 20, "y": 0 },
        "targets": [{ "expr": "godsview_margin_used_pct", "legendFormat": "Margin" }],
        "fieldConfig": { "defaults": { "min": 0, "max": 100, "unit": "percent", "thresholds": { "steps": [{ "value": null, "color": "green" }, { "value": 60, "color": "yellow" }, { "value": 85, "color": "red" }] } } }
      },
      {
        "title": "Order Flow by Type",
        "type": "timeseries",
        "gridPos": { "h": 8, "w": 12, "x": 0, "y": 4 },
        "targets": [
          { "expr": "rate(godsview_orders_total{type=\"market\"}[5m])", "legendFormat": "Market" },
          { "expr": "rate(godsview_orders_total{type=\"limit\"}[5m])", "legendFormat": "Limit" },
          { "expr": "rate(godsview_orders_total{type=\"stop\"}[5m])", "legendFormat": "Stop" },
          { "expr": "rate(godsview_orders_total{status=\"rejected\"}[5m])", "legendFormat": "Rejected" }
        ]
      },
      {
        "title": "Risk Metrics Over Time",
        "type": "timeseries",
        "gridPos": { "h": 8, "w": 12, "x": 12, "y": 4 },
        "targets": [
          { "expr": "godsview_portfolio_var_95", "legendFormat": "VaR 95%" },
          { "expr": "godsview_portfolio_var_99", "legendFormat": "VaR 99%" },
          { "expr": "godsview_current_drawdown", "legendFormat": "Current DD" },
          { "expr": "godsview_max_drawdown", "legendFormat": "Max DD" }
        ],
        "fieldConfig": { "defaults": { "unit": "percentunit" } }
      },
      {
        "title": "Position PnL by Symbol",
        "type": "bargauge",
        "gridPos": { "h": 8, "w": 12, "x": 0, "y": 12 },
        "targets": [{ "expr": "godsview_position_pnl_usd", "legendFormat": "{{ symbol }}" }],
        "fieldConfig": { "defaults": { "unit": "currencyUSD" } }
      },
      {
        "title": "WebSocket Connections",
        "type": "timeseries",
        "gridPos": { "h": 8, "w": 12, "x": 12, "y": 12 },
        "targets": [
          { "expr": "godsview_ws_connections", "legendFormat": "WS Clients" },
          { "expr": "godsview_sse_connections", "legendFormat": "SSE Clients" },
          { "expr": "rate(godsview_ws_messages_total[5m])", "legendFormat": "WS msg/s" }
        ]
      }
    ]
  }
}
