run = "corepack pnpm run dev"
entrypoint = "artifacts/api-server/src/index.ts"

[nix]
channel = "stable-24_05"

[env]
NODE_ENV = "development"
PORT = "3000"
CORS_ORIGIN = "http://localhost:5173"
GODSVIEW_SYSTEM_MODE = "paper"

[deployment]
run = ["sh", "-c", "corepack pnpm --filter @workspace/api-server run start"]
build = ["sh", "-c", "corepack enable && corepack pnpm install --frozen-lockfile && corepack pnpm run build"]
deploymentTarget = "cloudrun"

[[ports]]
localPort = 3000
externalPort = 80

[[ports]]
localPort = 5173
externalPort = 3001
