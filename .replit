run = "bash replit-start.sh"
entrypoint = "artifacts/api-server/dist/index.mjs"

[nix]
channel = "stable-24_05"

[env]
PORT = "3000"
NODE_ENV = "production"
GODSVIEW_SYSTEM_MODE = "paper"
GODSVIEW_TRUST_PROXY = "1"
CORS_ORIGIN = "https://$REPL_SLUG.$REPL_OWNER.repl.co,https://$REPL_SLUG.$REPL_OWNER.replit.app,https://$REPL_SLUG.$REPL_OWNER.replit.dev,http://localhost:3000"
# SECRETS — set in Replit Secrets panel (Tools → Secrets):
#   ANTHROPIC_API_KEY      — Claude API key (required for Super Intelligence)
#   TIINGO_API_KEY         — Market data
#   FRED_API_KEY           — Macro data
#   ALPHA_VANTAGE_API_KEY  — Indicators
#   FINNHUB_API_KEY        — Alt-data
#   ALPACA_API_KEY         — Live/paper trading (optional)
#   ALPACA_SECRET_KEY      — Live/paper trading (optional)

[deployment]
run = ["sh", "-c", "bash replit-start.sh"]
deploymentTarget = "cloudrun"

[[ports]]
localPort = 3000
externalPort = 80
