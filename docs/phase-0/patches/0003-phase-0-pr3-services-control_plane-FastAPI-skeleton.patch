diff --git a/services/control_plane/tests/test_errors.py b/services/control_plane/tests/test_errors.py
new file mode 100644
index 0000000..1850d7c
--- /dev/null
+++ b/services/control_plane/tests/test_errors.py
@@ -0,0 +1,29 @@
+"""Error envelope + validation error coverage."""
+
+from __future__ import annotations
+
+import pytest
+from httpx import AsyncClient
+
+
+@pytest.mark.asyncio
+async def test_unknown_route_returns_envelope(client: AsyncClient) -> None:
+    res = await client.get("/does/not/exist")
+    assert res.status_code == 404
+    body = res.json()
+    assert body["error"]["code"] == "not_found"
