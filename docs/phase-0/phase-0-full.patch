+++ b/infra/compose/docker-compose.yml
@@ -0,0 +1,136 @@
+# ─────────────────────────────────────────────────────────────────────
+# GodsView v2 — local development stack
+#
+# One-command bring-up for the entire dependency set the control plane
+# and web app talk to in dev. Matches production topology:
+#
+#   postgres-16     — primary OLTP store; asyncpg driver required
+#   redis-7         — rate-limit buckets, session hot path, pub/sub
+#   minio           — S3-compatible object store for recall screenshots
+#                     and audit export bundles
+#   localstack      — AWS service emulator (kinesis, sqs, secrets) so we
+#                     can exercise the AWS IaC path locally without a
+#                     real account
+#   mailhog         — SMTP sink for password-reset / alert email tests
+#
+# Ports are pinned and non-conflicting with common defaults so the stack
+# boots cleanly next to other projects.
+# ─────────────────────────────────────────────────────────────────────
+
+name: godsview-dev
+
+services:
+  postgres:
+    image: postgres:16-alpine
+    container_name: gv-postgres
+    restart: unless-stopped
+    environment:
+      POSTGRES_DB: godsview
+      POSTGRES_USER: godsview
+      POSTGRES_PASSWORD: godsview
+      # Force UTF-8 + deterministic collation so Alembic migrations
+      # behave identically in CI and on every dev laptop.
+      POSTGRES_INITDB_ARGS: "--encoding=UTF-8 --locale=C --lc-collate=C --lc-ctype=C"
+    ports:
+      - "5432:5432"
+    volumes:
+      - gv-postgres-data:/var/lib/postgresql/data
+      - ./init/postgres:/docker-entrypoint-initdb.d:ro
+    healthcheck:
+      test: ["CMD-SHELL", "pg_isready -U godsview -d godsview"]
+      interval: 5s
+      timeout: 3s
+      retries: 20
+      start_period: 5s
+
+  redis:
+    image: redis:7-alpine
+    container_name: gv-redis
+    restart: unless-stopped
+    command:
+      - redis-server
+      - --appendonly
+      - "yes"
+      - --maxmemory-policy
+      - "noeviction"
+    ports:
+      - "6379:6379"
+    volumes:
+      - gv-redis-data:/data
+    healthcheck:
+      test: ["CMD", "redis-cli", "ping"]
+      interval: 5s
+      timeout: 3s
+      retries: 20
+
+  minio:
+    image: minio/minio:RELEASE.2024-10-13T13-34-11Z
+    container_name: gv-minio
+    restart: unless-stopped
+    command: server /data --console-address ":9001"
+    environment:
+      MINIO_ROOT_USER: godsview
+      MINIO_ROOT_PASSWORD: godsview-dev-secret
+    ports:
+      - "9000:9000"   # S3 API
+      - "9001:9001"   # Console UI
+    volumes:
+      - gv-minio-data:/data
+    healthcheck:
+      test: ["CMD", "curl", "-fsS", "http://localhost:9000/minio/health/live"]
+      interval: 10s
+      timeout: 5s
+      retries: 10
+      start_period: 5s
+
+  minio-bootstrap:
+    # One-shot container that waits for MinIO to be healthy and then
+    # creates the buckets the control plane expects. Idempotent.
+    image: minio/mc:RELEASE.2024-10-08T09-37-26Z
+    container_name: gv-minio-bootstrap
+    depends_on:
+      minio:
+        condition: service_healthy
+    entrypoint: >
+      /bin/sh -c "
+      mc alias set gv http://minio:9000 godsview godsview-dev-secret &&
+      mc mb --ignore-existing gv/gv-recall &&
+      mc mb --ignore-existing gv/gv-audit-exports &&
+      mc mb --ignore-existing gv/gv-artifacts &&
+      mc anonymous set download gv/gv-artifacts &&
+      echo 'MinIO buckets provisioned: gv-recall, gv-audit-exports, gv-artifacts'
+      "
+    restart: "no"
+
+  localstack:
+    image: localstack/localstack:3.8
+    container_name: gv-localstack
+    restart: unless-stopped
+    environment:
+      SERVICES: kinesis,sqs,secretsmanager,ssm,sts,iam
+      DEFAULT_REGION: us-east-1
+      DEBUG: "0"
+    ports:
+      - "4566:4566"
+    volumes:
+      - gv-localstack-data:/var/lib/localstack
+    healthcheck:
+      test: ["CMD", "curl", "-fsS", "http://localhost:4566/_localstack/health"]
+      interval: 10s
+      timeout: 5s
+      retries: 12
+      start_period: 10s
+
+  mailhog:
+    image: mailhog/mailhog:v1.0.1
+    container_name: gv-mailhog
+    restart: unless-stopped
+    ports:
+      - "1025:1025"   # SMTP
+      - "8025:8025"   # Web UI
+
+volumes:
+  gv-postgres-data:
+  gv-redis-data:
+  gv-minio-data:
+  gv-localstack-data:
diff --git a/infra/compose/init/postgres/01_extensions.sql b/infra/compose/init/postgres/01_extensions.sql
new file mode 100644
index 0000000..cc4b00e
--- /dev/null
+++ b/infra/compose/init/postgres/01_extensions.sql
@@ -0,0 +1,24 @@
+-- GodsView v2 — Postgres extension bootstrap.
+--
+-- Runs once on the first container start (docker-entrypoint-initdb.d).
+-- Extensions are created in the godsview database that POSTGRES_DB seeds.
+--
+-- Rationale per extension:
+--   pgcrypto   — UUID generation + HMAC for audit-log row hashing.
+--   citext     — case-insensitive email column on users.
+--   pg_trgm    — trigram fuzzy search on audit log / recall text fields.
+--   btree_gin  — composite GIN indexes for hybrid JSONB + scalar queries.
+--
+-- These must be present before Alembic runs its first migration.
+
+CREATE EXTENSION IF NOT EXISTS "pgcrypto";
+CREATE EXTENSION IF NOT EXISTS "citext";
+CREATE EXTENSION IF NOT EXISTS "pg_trgm";
+CREATE EXTENSION IF NOT EXISTS "btree_gin";
+
+-- Sanity: emit the list so the compose log proves init ran.
+DO $$
+BEGIN
+  RAISE NOTICE 'godsview: extensions ready — pgcrypto, citext, pg_trgm, btree_gin';
+END;
+$$;
