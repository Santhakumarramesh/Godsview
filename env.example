# ──────────────────────────────────────────────────────────────────────────────
# GodsView — Complete Environment Configuration Example
# ──────────────────────────────────────────────────────────────────────────────
# This file shows all available environment variables for running the full
# GodsView trading system with all 14 microservices enabled.
#
# Copy this file to .env and fill in your actual values:
#   cp env.example .env
#
# Then run:
#   docker compose up -d        # Start all 14 services with docker-compose
#   npm run dev                 # Or run locally in development mode
#
# SECURITY WARNING:
# - Never commit .env with real API keys to version control
# - Use your deployment platform's secret manager (Railway, Vercel, etc.)
# - The ALPACA_SECRET_KEY and ANTHROPIC_API_KEY must be kept confidential
# ──────────────────────────────────────────────────────────────────────────────

# ══════════════════════════════════════════════════════════════════════════════
# SECTION 1: CORE SERVER CONFIGURATION
# ══════════════════════════════════════════════════════════════════════════════
# Basic Node.js API server and database settings

NODE_ENV=development
PORT=3001

# PostgreSQL database connection
# Format: postgresql://user:password@host:port/database
# For local development with docker-compose, use:
#   DATABASE_URL=postgresql://godsview:godsview_secret@postgres:5432/godsview
# For production (Neon, Supabase, Railway):
#   DATABASE_URL=postgresql://user:password@host.cloud.neon.tech/dbname?sslmode=require
DATABASE_URL=postgresql://godsview:godsview_secret@localhost:5432/godsview

# Connection pool settings
DB_POOL_MAX=10
POSTGRES_PASSWORD=godsview_secret

# CORS configuration
CORS_ORIGIN=http://localhost:3000

# Trust proxy headers (set to 1 for deployment behind reverse proxy)
TRUST_PROXY=0

# ══════════════════════════════════════════════════════════════════════════════
# SECTION 2: TRADING API CREDENTIALS (Alpaca)
# ══════════════════════════════════════════════════════════════════════════════
# Alpaca Securities API for stock trading

# Sign up at: https://alpaca.markets
# Get your keys from: https://app.alpaca.markets/brokerage/account/keys
ALPACA_API_KEY=PKxxxxxxxxxxxxxxxxxx
ALPACA_SECRET_KEY=xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx

# Choose paper (practice) or live trading endpoint
# Paper trading: https://paper-api.alpaca.markets (safe, no real money)
# Live trading: https://api.alpaca.markets (REAL MONEY)
ALPACA_BASE_URL=https://paper-api.alpaca.markets

# ══════════════════════════════════════════════════════════════════════════════
# SECTION 3: AI AGENT (Anthropic Claude)
# ══════════════════════════════════════════════════════════════════════════════
# Claude AI for decision making and trade veto logic

# Get API key from: https://console.anthropic.com
ANTHROPIC_API_KEY=sk-ant-xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx

# Which Claude model to use for veto decisions
CLAUDE_VETO_MODEL=claude-sonnet-4-5-20241022

# Timeout for Claude API calls (ms)
CLAUDE_TIMEOUT_MS=30000

# Retry policy for failed API calls
CLAUDE_MAX_RETRIES=1

# ══════════════════════════════════════════════════════════════════════════════
# SECTION 4: DATA PROVIDERS
# ══════════════════════════════════════════════════════════════════════════════
# Third-party APIs for market data and economic indicators

# ── Polygon.io (Stock market L2 order book data)
# Get key at: https://polygon.io
# Level 2 order book data helps identify real liquidity
POLYGON_API_KEY=
ORDERBOOK_ENABLED=true

# ── FRED API (Federal Reserve Economic Data)
# Get key at: https://fred.stlouisfed.org/docs/api/
# Used for economic context in trading decisions
FRED_API_KEY=

# ── Tiingo (Alternative market data source)
# Get key at: https://api.tiingo.com
TIINGO_API_KEY=

# ══════════════════════════════════════════════════════════════════════════════
# SECTION 5: TRADINGVIEW INTEGRATION
# ══════════════════════════════════════════════════════════════════════════════
# Webhook signals from TradingView charts

# Secret used to authenticate incoming TradingView webhook requests
# Create any random string: openssl rand -base64 32
# Use this same value in your TradingView webhook configuration
TV_WEBHOOK_SECRET=your-secret-webhook-key-change-me

# Economic calendar source
ECON_CALENDAR_URL=https://nfs.faireconomy.media/ff_calendar_thisweek.json

# ══════════════════════════════════════════════════════════════════════════════
# SECTION 6: SYSTEM SAFETY & GOVERNANCE
# ══════════════════════════════════════════════════════════════════════════════
# Critical controls to prevent losses and enforce risk limits

# ── Operating Mode (paper = safe, live_enabled = REAL MONEY)
# START IN PAPER MODE. Only switch to live_enabled after thorough testing.
GODSVIEW_SYSTEM_MODE=paper

# ── Operator Token (required to enable live trading)
# Must be set to enable GODSVIEW_SYSTEM_MODE=live_enabled
# Use a strong, random value: openssl rand -base64 32
GODSVIEW_OPERATOR_TOKEN=change-me-to-enable-live-trading

# ── Emergency Kill Switch
# Set to true to stop all trading immediately (no new positions)
GODSVIEW_KILL_SWITCH=false

# ── Loss Controls (per trading session)
# Stop trading after losing $250 USD in a single day
GODSVIEW_MAX_DAILY_LOSS_USD=250

# Maximum open position exposure as % of account
# 0.6 = 60% of account exposed to positions (conservative)
GODSVIEW_MAX_OPEN_EXPOSURE_PCT=0.6

# ── Trade Limits
# Maximum number of trades allowed in a single session
GODSVIEW_MAX_TRADES_PER_SESSION=10

# ── Cooldown After Losses
# After hitting 3 losing trades, pause for 30 minutes
GODSVIEW_COOLDOWN_AFTER_LOSSES=3
GODSVIEW_COOLDOWN_MINUTES=30

# ── Data Quality Gates
# Block trading if market data appears degraded/stale
GODSVIEW_BLOCK_ON_DEGRADED_DATA=true

# ── Live Trading Master Switch
# Controls whether the system can place real trades (if live_enabled mode)
# Set only after confirming safety limits and testing thoroughly
GODSVIEW_ENABLE_LIVE_TRADING=false

# ══════════════════════════════════════════════════════════════════════════════
# SECTION 7: PYTHON v2 MICROSERVICES
# ══════════════════════════════════════════════════════════════════════════════
# The complete Python analytics and execution stack

# ── Enable/Disable Python Services
# Set to true to enable the 14-service Python microservices architecture
PY_SERVICES_ENABLED=true

# ── Service URLs
# Gateway: Routes requests to specific Python microservices
PY_GATEWAY_URL=http://py-gateway:8000

# URL that Python services use to call back to Node API
NODE_API_URL=http://api:3001

# ── Storage & Database Paths
# These SQLite databases persist data across restarts:

# Governance audit log (tracks all decisions and trades)
GOVERNANCE_DB_PATH=/app/data/governance.db

# Chart screenshots and visual analysis artifacts
SCREENSHOT_DIR=/app/data/screenshots

# ML experiment tracking (model performance metrics)
EXPERIMENT_DB_PATH=/app/data/experiments.db

# Promotion pipeline state
PROMOTION_DB_PATH=/app/data/promotions.db

# ══════════════════════════════════════════════════════════════════════════════
# SECTION 8: RATE LIMITING & TIMEOUTS
# ══════════════════════════════════════════════════════════════════════════════
# Control request volume and timeout behavior

# Rate limit window (ms)
RATE_LIMIT_WINDOW_MS=60000

# Maximum requests per window
RATE_LIMIT_MAX=100

# Request timeout (ms)
REQUEST_TIMEOUT_MS=30000

# Server shutdown grace period (ms)
SHUTDOWN_TIMEOUT_MS=10000

# ══════════════════════════════════════════════════════════════════════════════
# QUICK START GUIDE
# ══════════════════════════════════════════════════════════════════════════════

# 1. DEVELOPMENT (Local Testing)
#    - Use DATABASE_URL with local postgres or PGlite
#    - Set GODSVIEW_SYSTEM_MODE=paper (no real money)
#    - Set NODE_ENV=development
#    - Run: npm run dev
#
# 2. DOCKER COMPOSE (Full System)
#    - Fill in ALPACA_API_KEY and ALPACA_SECRET_KEY (paper account)
#    - Fill in ANTHROPIC_API_KEY
#    - Run: docker compose up -d
#    - Check: docker compose logs -f api
#    - Services start at: http://localhost (nginx)
#                         http://localhost:3001 (API)
#                         http://localhost:5000 (MLflow)
#
# 3. BEFORE GOING LIVE
#    - Test thoroughly in paper mode first
#    - Review all loss controls (max daily loss, position limits)
#    - Verify webhook security (TV_WEBHOOK_SECRET)
#    - Use a new Alpaca account for live trading
#    - Start with small position sizes
#    - Only then set GODSVIEW_SYSTEM_MODE=live_enabled
#
# 4. PRODUCTION DEPLOYMENT
#    - Use Railway, Vercel, or similar platform
#    - Inject secrets via platform's secret manager
#    - Set NODE_ENV=production
#    - Enable CORS_ORIGIN for your domain
#    - Monitor logs and health endpoints
#
# ══════════════════════════════════════════════════════════════════════════════
