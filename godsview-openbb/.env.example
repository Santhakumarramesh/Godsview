ALPACA_API_KEY=
ALPACA_SECRET_KEY=
ALPACA_PAPER=true
ALPACA_DATA_FEED=iex

SYMBOL=BTCUSD
TIMEFRAME=1D
LOOKBACK=500

OPENBB_PROVIDER=yfinance

MODEL_TYPE=random_forest
MODEL_THRESHOLD_BUY=0.60
MODEL_THRESHOLD_SELL=0.40

MAX_RISK_PER_TRADE=0.01
MAX_DAILY_LOSS=0.03
DEFAULT_STOP_PCT=0.015

DRY_RUN=true
MPLCONFIGDIR=.cache/matplotlib
X_BEARER_TOKEN=
FTMO_CALENDAR_URL=https://ftmo.com/en/calendar/
SESSION_TIMEZONE=America/New_York
ALLOWED_SESSIONS=LONDON,NEW_YORK
MAX_POSITIONS=3
MIN_RR=1.5
