+// ── Phase 111: Execution Reliability Layer ───────────────────────────────────
+// Barrel export for all exec-reliability subsystems
+
+export { OrderStateMachine } from "./order_state_machine.js";
+export { BrokerReconciler } from "./broker_reconciler.js";
+export { FailsafeController } from "./failsafe_controller.js";
diff --git a/api-server/src/lib/exec_reliability/order_state_machine.ts b/api-server/src/lib/exec_reliability/order_state_machine.ts
