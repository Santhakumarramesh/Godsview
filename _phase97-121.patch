+      adaptiveOptimizer: {
+        status: "ok",
+        pendingRules: optimizationRules.length,
+        lastOptimization: new Date(Date.now() - 45 * 60_000).toISOString(),
+      },
+    },
+    uptime: process.uptime(),
+  });
+});
+
+export default router;
