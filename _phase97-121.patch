+        if (restriction.expiresAt > now) {
+          if (restriction.type === 'no_new_positions' || restriction.type === 'close_only') {
+            isLocked = true;
+          }
+        }
+      }
+    });
+
+    return isLocked;
+  }
+
+  public getActiveLockouts(): Restriction[] {
+    const now = Date.now();
+    const active: Restriction[] = [];
+
+    this.activeLockouts.forEach((restriction) => {
