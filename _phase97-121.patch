+
+const C = {
+  bg: "#0e0e0f", card: "#1a191b", cardAlt: "#141316",
+  border: "#2a2a2d", borderFocus: "#3a3a3f",
+  text: "#e2e2e6", textDim: "#8b8b92", textMuted: "#5a5a62",
