+    avgLoss: -1.0,
+    expectancy: 1.67,
+    bestSetups: ["squeeze_breakout", "volatility_expansion"],
+    blocked: false,
+    lastUpdated: new Date(Date.now() - 1800_000).toISOString(),
+  },
+  {
+    regime: "expansion",
+    totalSignals: 41,
