+                backgroundColor: item.pnl > 0 ? C.green : C.red,
+                opacity: 0.7,
+              }} />
+              <div style={{
+                position: 'absolute',
+                left: `${(item.pnl / maxPnL) * 100 - 2}%`,
+                top: '50%',
