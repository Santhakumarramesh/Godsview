+router.get("/snapshot", (_req: Request, res: Response) => {
+  const symbolSentiments: Record<string, ReturnType<typeof mockSentiment>> = {};
+  for (const sym of symbols) {
+    symbolSentiments[sym] = mockSentiment(sym, biases[sym] ?? 0);
