+    });
+
+    return {
+      totalPostMortems: postMortems.length,
+      byType,
+      byRootCause,
+      commonFactors,
+      strategyPatterns,
+      timeOfDayCorrelation,
+      topLessons: Array.from(lessonSet).slice(0, 10),
+    };
+  }
