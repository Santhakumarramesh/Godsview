+                  position: 'relative',
+                  group: 'hover',
+                }}
+                title={`Date: ${day.date}\nPnL: $${day.pnl.toFixed(0)}\nTrades: ${day.trades}\nWin Rate: ${(day.winRate * 100).toFixed(0)}%`}
