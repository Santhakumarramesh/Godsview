+// ============================================================================
+// SECTION 4: ATTRIBUTION BREAKDOWN
+// ============================================================================
+
+interface AttributionBar {
+  name: string;
+  pnl: number;
+  winRate: number;
+}
+
+const defaultAttribution: Record<string, AttributionBar[]> = {
+  strategy: [
