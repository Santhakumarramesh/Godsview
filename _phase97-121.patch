+// 7 endpoints for feed health, validation stats, stale monitoring, sessions, snapshots, store stats
+
+import { Router, type Request, type Response } from "express";
+
+const router = Router();
+
+// ── Mock: Feed Health ───────────────────────────────────────────────────────
+
+const FEEDS = [
