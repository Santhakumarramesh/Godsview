+    return {
+      timestamp: this.lastScanTimestamp,
+      deadCodeScore,
+      configScore,
+      testScore,
+      overallScore: this.getHealthScore(),
+      deadCodeCount,
+      configRisks,
+      testCoverage,
+      modeConsistency: this.getModeConsistency(),
+      recommendations
+    };
+  }
