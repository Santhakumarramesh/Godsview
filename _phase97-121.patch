+
+            <div
+              style={{
+                backgroundColor: C.cardAlt,
+                padding: "12px",
+                borderRadius: "4px",
+                fontSize: "12px",
+                color: C.textDim,
+                lineHeight: "1.5",
+                borderLeft: `3px solid ${getRiskColor(pair.riskLevel)}`,
+              }}
+            >
+              {pair.recommendation}
+            </div>
+          </div>
