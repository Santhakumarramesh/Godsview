+              <span
+                style={{
+                  backgroundColor: color,
+                  color: C.bg,
+                  padding: '3px 8px',
+                  borderRadius: '4px',
+                  fontSize: '11px',
+                  fontWeight: 600,
+                  fontFamily: C.mono,
