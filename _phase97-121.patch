+    const cutoffTime = now - days * 24 * 60 * 60 * 1000;
+
+    return this.eventHistory.filter((impact) => impact.eventTime >= cutoffTime);
+  }
+
+  public recordEventImpact(
+    eventId: string,
+    eventName: string,
