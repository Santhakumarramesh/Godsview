+                  const x = (i / 100) * 250 + 25;
+                  const z = (i / 100 - 0.5) * 4;
+                  const y = 160 - Math.exp(-(z * z) / 2) * 80;
+                  return `${i === 0 ? 'M' : 'L'} ${x} ${y}`;
+                }).join(' ')}
+                stroke={C.accent}
+                strokeWidth="1.5"
+                fill="none"
