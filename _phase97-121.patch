+
+const overallFeedHealth = FEEDS.some(f => f.status === "active" && f.healthScore >= 90) ? "healthy" : FEEDS.some(f => f.healthScore >= 70) ? "degraded" : "critical";
+
+// ── Mock: Validation Stats ──────────────────────────────────────────────────
+
+const VALIDATION = {
+  totalProcessed: 847293,
