# ─────────────────────────────────────────────────────────────────────
# GodsView v2 — development environment template
#
# Copy to ops/envs/.env.dev (gitignored) before running `make dev-up`.
# The control plane, web app, and ops scripts all source these values.
# ─────────────────────────────────────────────────────────────────────

# ── app ──────────────────────────────────────────────────────────────
APP_ENV=development
LOG_LEVEL=debug
CORRELATION_ID_HEADER=x-correlation-id

# ── control plane ────────────────────────────────────────────────────
CONTROL_PLANE_HOST=0.0.0.0
CONTROL_PLANE_PORT=8000
CONTROL_PLANE_ORIGIN=http://localhost:8000

# Forces asyncpg driver (postgres+asyncpg://) per Settings validator.
DATABASE_URL=postgresql+asyncpg://godsview:godsview@localhost:5432/godsview

REDIS_URL=redis://localhost:6379/0

# ── auth ─────────────────────────────────────────────────────────────
# Dev-only HS256 signing key. Rotate for every shared environment.
# Production uses RS256 backed by KMS — see AWS deploy docs.
JWT_SIGNING_KEY=dev-signing-key-change-me-0123456789abcdef-dev
JWT_ALGORITHM=HS256
ACCESS_TOKEN_TTL_SECONDS=900
REFRESH_TOKEN_TTL_SECONDS=604800

# ── bootstrap admin (seed) ───────────────────────────────────────────
BOOTSTRAP_ADMIN_EMAIL=admin@godsview.local
BOOTSTRAP_ADMIN_PASSWORD=godsview-dev-admin-change-me

# ── object storage (MinIO in dev) ────────────────────────────────────
S3_ENDPOINT_URL=http://localhost:9000
S3_ACCESS_KEY=godsview
S3_SECRET_KEY=godsview-dev-secret
S3_REGION=us-east-1
S3_BUCKET_RECALL=gv-recall
S3_BUCKET_AUDIT_EXPORTS=gv-audit-exports
S3_BUCKET_ARTIFACTS=gv-artifacts

# ── email (MailHog in dev) ───────────────────────────────────────────
SMTP_HOST=localhost
SMTP_PORT=1025
SMTP_FROM=noreply@godsview.local

# ── localstack (AWS emulator) ────────────────────────────────────────
AWS_ENDPOINT_URL=http://localhost:4566
AWS_REGION=us-east-1
AWS_ACCESS_KEY_ID=test
AWS_SECRET_ACCESS_KEY=test

# ── web app ──────────────────────────────────────────────────────────
NEXT_PUBLIC_CONTROL_PLANE_ORIGIN=http://localhost:8000
NEXT_PUBLIC_ENV_LABEL=dev
GODSVIEW_CONTROL_PLANE_ORIGIN=http://localhost:8000

# ── safety floor (Decision #4 — DO NOT flip in shared envs) ──────────
# These mirror the seed defaults and are read at boot by the safety
# middleware. Keep KILL_SWITCH_ON_BOOT=1 in any multi-user environment.
KILL_SWITCH_ON_BOOT=1
ALLOW_LIVE_EXECUTION=0
ALLOW_AUTONOMOUS_INTELLIGENCE=0
