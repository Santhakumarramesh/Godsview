{
  "name": "@gv/ui",
  "version": "0.1.0",
  "private": true,
  "type": "module",
  "exports": {
    ".": {
      "workspace": "./src/index.ts",
      "import": "./src/index.ts",
      "types": "./src/index.ts"
    },
    "./*": {
      "workspace": "./src/*.tsx",
      "import": "./src/*.tsx",
      "types": "./src/*.tsx"
    }
  },
  "main": "./src/index.ts",
  "types": "./src/index.ts",
  "sideEffects": ["*.css"],
  "scripts": {
    "typecheck": "tsc -p tsconfig.json --noEmit",
    "build": "tsc -p tsconfig.json",
    "test": "echo 'no tests yet for @gv/ui' && exit 0",
    "lint": "echo 'lint todo' && exit 0",
    "clean": "rm -rf dist .turbo *.tsbuildinfo"
  },
  "peerDependencies": {
    "react": "^19.0.0",
    "react-dom": "^19.0.0"
  },
  "dependencies": {
    "clsx": "2.1.1",
    "tailwind-merge": "3.5.0"
  },
  "devDependencies": {
    "@types/react": "^19.2.0",
    "@types/react-dom": "^19.2.0",
    "react": "19.1.0",
    "react-dom": "19.1.0",
    "typescript": "~5.9.2"
  }
}
