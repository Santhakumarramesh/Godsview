{
  "name": "@gv/api-client",
  "version": "0.1.0",
  "private": true,
  "type": "module",
  "exports": {
    ".": {
      "workspace": "./src/index.ts",
      "import": "./src/index.ts",
      "types": "./src/index.ts"
    },
    "./*": {
      "workspace": "./src/*.ts",
      "import": "./src/*.ts",
      "types": "./src/*.ts"
    }
  },
  "main": "./src/index.ts",
  "types": "./src/index.ts",
  "scripts": {
    "typecheck": "tsc -p tsconfig.json --noEmit",
    "build": "tsc -p tsconfig.json",
    "test": "echo 'no tests yet for @gv/api-client' && exit 0",
    "lint": "echo 'lint todo' && exit 0",
    "clean": "rm -rf dist .turbo *.tsbuildinfo",
    "codegen": "echo 'openapi codegen wired in Phase 2 when ingestion ships'"
  },
  "dependencies": {
    "@gv/types": "workspace:*",
    "zod": "^3.25.76"
  },
  "devDependencies": {
    "typescript": "~5.9.2"
  }
}
