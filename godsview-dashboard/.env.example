# ── GodsView Dashboard Environment ──────────────────────────────────
# Copy this file to .env and fill in your values.

# API base URL — points to the Express backend
# In development, Vite proxies /api to this address
VITE_API_BASE=http://localhost:3000/api

# WebSocket URL for real-time data feed
VITE_WS_URL=ws://localhost:3000/ws

# Alpaca Paper Trading (used by backend, listed here for reference)
# ALPACA_API_KEY=your_alpaca_key
# ALPACA_API_SECRET=your_alpaca_secret
# ALPACA_BASE_URL=https://paper-api.alpaca.markets

# Optional: Anthropic API key for Claude layer in the pipeline
# ANTHROPIC_API_KEY=your_anthropic_key

# Optional: Enable debug logging in browser console
# VITE_DEBUG=true
