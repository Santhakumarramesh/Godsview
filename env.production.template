# ── GodsView Production Environment ──────────────────────────────────────────
# SECURITY: This file should be managed by your deployment platform's
# secret manager (Railway, Render, Vercel, etc.) — never commit real values.
# This file serves as a template showing what's required in production.

# ── Database (Neon / Supabase / Railway Postgres) ────────────────────────────
DATABASE_URL=postgres://user:password@host:5432/godsview?sslmode=require

# ── Alpaca (Paper → Live) ────────────────────────────────────────────────────
ALPACA_API_KEY=REQUIRED
ALPACA_SECRET_KEY=REQUIRED
# Paper: https://paper-api.alpaca.markets | Live: https://api.alpaca.markets
ALPACA_BASE_URL=https://paper-api.alpaca.markets

# ── Anthropic (Claude Veto Layer 6) ──────────────────────────────────────────
ANTHROPIC_API_KEY=REQUIRED

# ── Server ───────────────────────────────────────────────────────────────────
NODE_ENV=production
PORT=3000
CORS_ORIGINS=https://yourdomain.com
TRUST_PROXY=1

# ── System Mode ──────────────────────────────────────────────────────────────
# "paper" = paper trading with real signals | "live_enabled" = real money execution
GODSVIEW_SYSTEM_MODE=paper
# Operator token is required when GODSVIEW_SYSTEM_MODE=live_enabled
GODSVIEW_OPERATOR_TOKEN=REQUIRED

# ── Rate Limiting ────────────────────────────────────────────────────────────
RATE_LIMIT_WINDOW_MS=60000
RATE_LIMIT_MAX=100

# ── Timeouts ─────────────────────────────────────────────────────────────────
REQUEST_TIMEOUT_MS=30000
SHUTDOWN_TIMEOUT_MS=10000
