# ── GodsView Production Environment (Full System) ──────────────────────────
# SECURITY: This file should be managed by your deployment platform's
# secret manager (Railway, Render, Vercel, etc.) — never commit real values.
# This file serves as a template showing all required and optional variables.
# Copy this to .env and fill in your values.

# ══════════════════════════════════════════════════════════════════════════════
# CORE SERVICE CONFIGURATION
# ══════════════════════════════════════════════════════════════════════════════

# ── Node.js API Server ───────────────────────────────────────────────────────
NODE_ENV=production
PORT=3001
CORS_ORIGIN=https://yourdomain.com
TRUST_PROXY=1

# ── Database (PostgreSQL — Neon / Supabase / Railway) ────────────────────────
DATABASE_URL=postgres://user:password@host:5432/godsview?sslmode=require
DB_POOL_MAX=10
DB_EXTERNAL_PORT=5432
POSTGRES_PASSWORD=godsview_secret

# ══════════════════════════════════════════════════════════════════════════════
# TRADING API CREDENTIALS
# ══════════════════════════════════════════════════════════════════════════════

# ── Alpaca Trading API (Paper or Live) ───────────────────────────────────────
ALPACA_API_KEY=REQUIRED
ALPACA_SECRET_KEY=REQUIRED
# Paper: https://paper-api.alpaca.markets | Live: https://api.alpaca.markets
ALPACA_BASE_URL=https://paper-api.alpaca.markets

# ── Anthropic API (Claude Veto Layer) ───────────────────────────────────────
ANTHROPIC_API_KEY=REQUIRED
CLAUDE_VETO_MODEL=claude-sonnet-4-5-20241022
CLAUDE_TIMEOUT_MS=30000
CLAUDE_MAX_RETRIES=1

# ══════════════════════════════════════════════════════════════════════════════
# MARKET DATA PROVIDERS
# ══════════════════════════════════════════════════════════════════════════════

# ── Polygon.io (L2 Order Book Data) ──────────────────────────────────────────
POLYGON_API_KEY=
ORDERBOOK_ENABLED=true

# ── FRED Economic Data (Federal Reserve) ─────────────────────────────────────
FRED_API_KEY=

# ── Tiingo Market Data ───────────────────────────────────────────────────────
TIINGO_API_KEY=

# ══════════════════════════════════════════════════════════════════════════════
# TRADINGVIEW & WEBHOOKS
# ══════════════════════════════════════════════════════════════════════════════

# ── TradingView Webhook Authentication ───────────────────────────────────────
# Secret used to verify TradingView webhook requests
TV_WEBHOOK_SECRET=change-me

# ── Economic Calendar ────────────────────────────────────────────────────────
ECON_CALENDAR_URL=https://nfs.faireconomy.media/ff_calendar_thisweek.json

# ══════════════════════════════════════════════════════════════════════════════
# SYSTEM SAFETY & GOVERNANCE
# ══════════════════════════════════════════════════════════════════════════════

# ── System Operating Mode ───────────────────────────────────────────────────
# "paper" = Paper trading mode (safe, no real money)
# "live_enabled" = Real money execution (DANGEROUS — requires OPERATOR_TOKEN)
GODSVIEW_SYSTEM_MODE=paper

# ── Operator Authorization ──────────────────────────────────────────────────
# Required when GODSVIEW_SYSTEM_MODE=live_enabled
GODSVIEW_OPERATOR_TOKEN=change-me

# ── Kill Switch ──────────────────────────────────────────────────────────────
# Set to true to stop all trading immediately
GODSVIEW_KILL_SWITCH=false

# ── Loss Controls ────────────────────────────────────────────────────────────
GODSVIEW_MAX_DAILY_LOSS_USD=250
GODSVIEW_MAX_OPEN_EXPOSURE_PCT=0.6
GODSVIEW_MAX_TRADES_PER_SESSION=10

# ── Cooldown After Losses ───────────────────────────────────────────────────
GODSVIEW_COOLDOWN_AFTER_LOSSES=3
GODSVIEW_COOLDOWN_MINUTES=30

# ── Data Quality Gates ───────────────────────────────────────────────────────
# Block trading if market data is degraded
GODSVIEW_BLOCK_ON_DEGRADED_DATA=true

# ── Live Trading (Master Enable) ─────────────────────────────────────────────
GODSVIEW_ENABLE_LIVE_TRADING=false

# ══════════════════════════════════════════════════════════════════════════════
# PYTHON v2 MICROSERVICES
# ══════════════════════════════════════════════════════════════════════════════

# ── Enable Python Services ──────────────────────────────────────────────────
PY_SERVICES_ENABLED=true
PY_GATEWAY_URL=http://py-gateway:8000

# ── Node API URL for Python Services ────────────────────────────────────────
# URL that Python services use to call back to Node API
NODE_API_URL=http://api:3001

# ── Data & Storage Paths ────────────────────────────────────────────────────
# Governance audit log
GOVERNANCE_DB_PATH=/app/data/governance.db

# Chart screenshots
SCREENSHOT_DIR=/app/data/screenshots

# ML experiment tracking
EXPERIMENT_DB_PATH=/app/data/experiments.db

# Promotion pipeline
PROMOTION_DB_PATH=/app/data/promotions.db

# ══════════════════════════════════════════════════════════════════════════════
# RATE LIMITING & TIMEOUTS
# ══════════════════════════════════════════════════════════════════════════════

RATE_LIMIT_WINDOW_MS=60000
RATE_LIMIT_MAX=100
REQUEST_TIMEOUT_MS=30000
SHUTDOWN_TIMEOUT_MS=10000
