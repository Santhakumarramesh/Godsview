# ══════════════════════════════════════════════════════════════════════════════
# GodsView — .gitignore (production)
# ══════════════════════════════════════════════════════════════════════════════

# ── Build outputs ─────────────────────────────────────────────────────────────
dist/
build/
tmp/
out-tsc/
*.tsbuildinfo
.turbo/
.cache/

# ── Dependencies ──────────────────────────────────────────────────────────────
node_modules/
.pnpm-store/

# ── Secrets & environment ─────────────────────────────────────────────────────
.env
.env.*
!.env.example
credentials.json
*.pem
*.key

# ── Runtime state ─────────────────────────────────────────────────────────────
.runtime/
**/.runtime/
*.runtime.json
*_guard_state*.json

# ── Temp files ────────────────────────────────────────────────────────────────
_tmp_*
*.patch
*.backup
_brain_sync.b64
_brain_sync.tar.gz

# ── System / OS files ─────────────────────────────────────────────────────────
.DS_Store
Thumbs.db
*.swp
*.swo
*~

# ── Python ────────────────────────────────────────────────────────────────────
__pycache__/
*.pyc
*.pyo
.venv/
venv/

# ── IDE / Editor ──────────────────────────────────────────────────────────────
/.idea/
.vscode/*
!.vscode/settings.json
!.vscode/launch.json
!.vscode/extensions.json

# ── Claude / AI assistant ────────────────────────────────────────────────────
.claude/

# ── Logs ──────────────────────────────────────────────────────────────────────
*.log
npm-debug.log*
pnpm-debug.log*

# ── Coverage / Testing ───────────────────────────────────────────────────────
coverage/
.nyc_output/

# ── Local scratch ─────────────────────────────────────────────────────────────
attached_assets/

# ── Build artifact guards ─────────────────────────────────────────────────────
artifacts/api-server/public/public/

# ── Nested clone prevention ───────────────────────────────────────────────────
Godsview/
