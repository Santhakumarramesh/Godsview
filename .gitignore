# ══════════════════════════════════════════════════════════════════════════════
# GodsView — .gitignore
# ══════════════════════════════════════════════════════════════════════════════

# ── Build outputs ─────────────────────────────────────────────────────────────
dist/
build/
tmp/
out-tsc/
*.tsbuildinfo
.expo/
.expo-shared/
.next/
.turbo/
.cache/

# ── Dependencies ──────────────────────────────────────────────────────────────
node_modules/
.pnpm-store/
.yarn/

# ── Secrets & environment ─────────────────────────────────────────────────────
.env
.env.*
!.env.example
credentials.json
*.pem
*.key

# ── Runtime state (never track) ───────────────────────────────────────────────
.runtime/
**/.runtime/
*.runtime.json
*_guard_state*.json

# ── Temp files ────────────────────────────────────────────────────────────────
_tmp_*
_brain_sync.b64
_brain_sync.tar.gz

# ── System / OS files ─────────────────────────────────────────────────────────
.DS_Store
Thumbs.db
*.swp
*.swo
*~

# ── Python ────────────────────────────────────────────────────────────────────
__pycache__/
*.pyc
*.pyo
.venv/
venv/

# ── IDE / Editor ──────────────────────────────────────────────────────────────
/.idea/
.project
.classpath
.c9/
*.launch
.settings/
*.sublime-workspace
.vscode/*
!.vscode/settings.json
!.vscode/tasks.json
!.vscode/launch.json
!.vscode/extensions.json
.cursor/rules/nx-rules.mdc
.github/instructions/nx.instructions.md

# ── Replit (not needed for production) ────────────────────────────────────────
.replit
.replitignore
replit.md
.local/
.bashrc
.bash_logout
.profile

# ── Claude / AI assistant ────────────────────────────────────────────────────
.claude/

# ── Logs ──────────────────────────────────────────────────────────────────────
*.log
npm-debug.log*
yarn-error.log*
pnpm-debug.log*

# ── Coverage / Testing ───────────────────────────────────────────────────────
/coverage/
/.nyc_output/

# ── Local scratch ─────────────────────────────────────────────────────────────
attached_assets/
godsview_engine_analysis_dashboard.html

# ── GodsView Python runtime artifacts ─────────────────────────────────────────
godsview-openbb/data/processed/
godsview-openbb/charts/
godsview-openbb/reports/
godsview-openbb/memory/

# ── Build artifact guards ─────────────────────────────────────────────────────
artifacts/api-server/public/public/

# ── Nested clone prevention ───────────────────────────────────────────────────
Godsview/
