# Public origin of the FastAPI control plane consumed by /api/v1/* rewrites.
GODSVIEW_CONTROL_PLANE_ORIGIN=http://localhost:8000

# Public-facing base URL the React client uses when calling the API.
NEXT_PUBLIC_GODSVIEW_API_BASE=/api/v1

# Display label shown in the top bar.
NEXT_PUBLIC_GODSVIEW_ENV=local
