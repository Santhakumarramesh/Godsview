# ─────────────────────────────────────────────────
# GodsView — Environment Configuration
# Copy to .env and fill in your values
# ─────────────────────────────────────────────────

# ── Server ────────────────────────────────────────
PORT=3001
NODE_ENV=development
CORS_ORIGIN=http://localhost:5173,http://localhost:3000
LOG_LEVEL=info

# ── System Mode ───────────────────────────────────
# Options: paper_only | live_enabled | backtest_only
GODSVIEW_SYSTEM_MODE=paper_only
# GODSVIEW_ENABLE_LIVE_TRADING=false  # (legacy, use SYSTEM_MODE)

# ── Alpaca (Paper Trading) ────────────────────────
ALPACA_API_KEY=PK...
ALPACA_SECRET_KEY=...
# ── Claude AI (Veto Layer) ────────────────────────
ANTHROPIC_API_KEY=sk-ant-...
# CLAUDE_VETO_MODEL=claude-sonnet-4-5-20241022
# CLAUDE_TIMEOUT_MS=30000
# CLAUDE_MAX_RETRIES=1

# ── Security ──────────────────────────────────────
# Set to require API key on all /api/* routes
# Leave empty for open access (dev mode)
# GODSVIEW_API_KEY=
GODSVIEW_OPERATOR_TOKEN=

# ── Risk Engine ───────────────────────────────────
GODSVIEW_KILL_SWITCH=false
# GODSVIEW_MAX_RISK_PER_TRADE_PCT=0.01
# GODSVIEW_MAX_DAILY_LOSS_USD=250
# GODSVIEW_MAX_OPEN_EXPOSURE_PCT=0.6
# GODSVIEW_MAX_CONCURRENT_POSITIONS=3
# GODSVIEW_MAX_TRADES_PER_SESSION=10
# GODSVIEW_COOLDOWN_AFTER_LOSSES=3
# GODSVIEW_COOLDOWN_MINUTES=30
# GODSVIEW_BLOCK_ON_DEGRADED_DATA=true
# ── Server Tuning ─────────────────────────────────
# GODSVIEW_TRUST_PROXY=false
# GODSVIEW_REQUEST_BODY_LIMIT=1mb
# GODSVIEW_REQUEST_TIMEOUT_MS=45000
# GODSVIEW_KEEPALIVE_TIMEOUT_MS=65000
# GODSVIEW_HEADERS_TIMEOUT_MS=66000
# GODSVIEW_SHUTDOWN_TIMEOUT_MS=20000
# GODSVIEW_MAX_REQUESTS_PER_SOCKET=200

# ── Rate Limiting ─────────────────────────────────
# GODSVIEW_RATE_LIMIT_WINDOW_MS=60000
# GODSVIEW_RATE_LIMIT_MAX=300

# ── Production Gate Thresholds ────────────────────
# PROD_MIN_WIN_PROB=0.57
# PROD_MIN_EDGE=0.08
# PROD_MAX_SPREAD_PCT=0.003
# PROD_MAX_DAILY_TRADES=15
# PROD_COOLDOWN_MS=60000