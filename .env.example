# ─────────────────────────────────────────────────────────────────
# GodsView — Environment Configuration
# Copy to .env and fill in your values
# ─────────────────────────────────────────────────────────────────
# REQUIRED vars are marked with [REQUIRED]
# CHANGE vars must be changed from default before production use
# ─────────────────────────────────────────────────────────────────

# ── Runtime ──────────────────────────────────────────────────────
NODE_ENV=production
PORT=3001                    # [REQUIRED] TCP port the API server listens on

# ── Database ─────────────────────────────────────────────────────
# Docker Compose sets this automatically. Override for external DB.
DATABASE_URL=postgresql://godsview:godsview_secret@postgres:5432/godsview  # [REQUIRED]
POSTGRES_PASSWORD=godsview_secret   # [CHANGE] Use a strong password in production
DB_POOL_MAX=10
DB_EXTERNAL_PORT=5432

# ── Redis (optional, production recommended) ────────────────────
REDIS_URL=                           # e.g. redis://redis:6379 — used for distributed caching
                                     # If empty, falls back to in-process LRU cache

# ── Memory Store ────────────────────────────────────────────────
MEMORY_STORE_PATH=                   # Persistent path for memory store (default: /data/memory in prod, /tmp/godsview-memory in dev)
                                     # In production, point to EBS or EFS mount for data persistence across restarts

# ── Dashboard / CORS ─────────────────────────────────────────────
# CORS_ORIGIN is REQUIRED in production (NODE_ENV=production)
# Use your public domain(s), comma-separated for multiple
VITE_API_BASE_URL=http://localhost:3001
CORS_ORIGIN=https://yourdomain.com  # [REQUIRED in production] comma-separated origins
HTTP_PORT=80
GODSVIEW_TRUST_PROXY=true           # set true behind nginx/caddy/load-balancer

# ── Alpaca Trading API ───────────────────────────────────────────
# Paper trading: ALPACA_BASE_URL=https://paper-api.alpaca.markets
# Live trading:  ALPACA_BASE_URL=https://api.alpaca.markets
ALPACA_API_KEY=                      # [REQUIRED for live/paper trading]
ALPACA_SECRET_KEY=                   # [REQUIRED for live/paper trading]
ALPACA_BASE_URL=https://paper-api.alpaca.markets

# ── Claude AI (Veto Layer) ───────────────────────────────────────
ANTHROPIC_API_KEY=                   # [REQUIRED for AI reasoning/veto layer]
CLAUDE_VETO_MODEL=claude-sonnet-4-6
CLAUDE_TIMEOUT_MS=30000
CLAUDE_MAX_RETRIES=1

# ── Auth & Security ──────────────────────────────────────────────
# Operator token gates destructive actions (kill-switch, config changes)
GODSVIEW_OPERATOR_TOKEN=             # [REQUIRED] Generate with: openssl rand -hex 32
# Optional API key for all /api/* routes. If unset, no auth is required.
# GODSVIEW_API_KEY=                  # set to enable global API key auth

# ── System Mode ──────────────────────────────────────────────────
# demo         = read-only, mock data displayed
# paper        = real market data, paper trade execution (RECOMMENDED default)
# live_disabled = real data, live account, execution disabled
# live_enabled  = real data, live account, execution ENABLED (requires operator token + Alpaca keys)
GODSVIEW_SYSTEM_MODE=paper           # [CHANGE] Start with paper before enabling live

# ── Safety Controls ──────────────────────────────────────────────
GODSVIEW_KILL_SWITCH=false
GODSVIEW_MAX_DAILY_LOSS_USD=250      # Hard daily loss cap in USD
GODSVIEW_MAX_RISK_PER_TRADE_PCT=0.01 # Max risk per trade as fraction of account (0.01 = 1%)
GODSVIEW_MAX_OPEN_EXPOSURE_PCT=0.6   # Max total open exposure as fraction of account
GODSVIEW_MAX_CONCURRENT_POSITIONS=3
GODSVIEW_MAX_TRADES_PER_SESSION=10
GODSVIEW_COOLDOWN_AFTER_LOSSES=3     # Consecutive losses before cooldown triggers
GODSVIEW_COOLDOWN_MINUTES=30
GODSVIEW_BLOCK_ON_DEGRADED_DATA=true

# ── Production Watchdog (readiness auto-enforcement) ─────────────
PRODUCTION_WATCHDOG_AUTO_START=true
PRODUCTION_WATCHDOG_INTERVAL_MS=45000
PRODUCTION_WATCHDOG_AUTO_ENFORCE=true
PRODUCTION_WATCHDOG_NOT_READY_TRIP_COUNT=3
PRODUCTION_WATCHDOG_DEGRADED_WARN_COUNT=4
PRODUCTION_WATCHDOG_AUTO_PAUSE_AUTONOMY=true
PRODUCTION_WATCHDOG_AUTO_KILL_SWITCH=true
PRODUCTION_WATCHDOG_INCLUDE_PREFLIGHT=false

# ── Session Controls ─────────────────────────────────────────────
GODSVIEW_ALLOW_SESSION_ASIAN=true
GODSVIEW_ALLOW_SESSION_LONDON=true
GODSVIEW_ALLOW_SESSION_NY=true
GODSVIEW_NEWS_LOCKOUT_ACTIVE=false

# ── Performance Tuning ───────────────────────────────────────────
GODSVIEW_RATE_LIMIT_WINDOW_MS=60000  # Rate limit window (ms)
GODSVIEW_RATE_LIMIT_MAX=300          # Max requests per window per IP
GODSVIEW_REQUEST_TIMEOUT_MS=45000
GODSVIEW_KEEPALIVE_TIMEOUT_MS=65000
GODSVIEW_SHUTDOWN_TIMEOUT_MS=20000
GODSVIEW_REQUEST_BODY_LIMIT=1mb

# ── External Data ────────────────────────────────────────────────
ECON_CALENDAR_URL=https://nfs.faireconomy.media/ff_calendar_thisweek.json

# ── Brain Engine ─────────────────────────────────────────────────
BRAIN_MODE=paper
BRAIN_AUTOSTART=false
BRAIN_MIN_SCORE=0.6
BRAIN_MIN_WIN_PROB=0.55
BRAIN_MAX_POSITIONS=5
BRAIN_MAX_DAILY_TRADES=20
BRAIN_MAX_DAILY_LOSS_R=3
BRAIN_RISK_PER_TRADE_PCT=1
BRAIN_ACCOUNT_EQUITY=10000
BRAIN_EXECUTION_BRIDGE=false
BRAIN_MTF_ENABLED=true
BRAIN_MTF_MIN_ALIGNMENT=0.6
BRAIN_WEBHOOK_SECRET=
BRAIN_WEBHOOK_URL=

# ── Execution Guards ─────────────────────────────────────────────
EXEC_AUTONOMY_GUARD_AUTO_HALT=true
EXEC_INCIDENT_AUTO_HALT=true
EXEC_MARKET_GUARD_AUTO_HALT=true
EXEC_SAFETY_SUPERVISOR_AUTO_START=true
EXEC_SAFETY_SUPERVISOR_AUTO_ENFORCE=true
EXEC_SAFETY_SUPERVISOR_INTERVAL_MS=30000

# ── Strategy Governance ──────────────────────────────────────────
STRATEGY_GOVERNOR_AUTO_START=false
STRATEGY_GOVERNOR_AUTO_ENFORCE=false
STRATEGY_GOVERNOR_INTERVAL_MS=60000
STRATEGY_ALLOCATOR_AUTO_START=false
STRATEGY_EVOLUTION_AUTO_START=false

# ── Autonomy Supervisor ──────────────────────────────────────────
AUTONOMY_SUPERVISOR_AUTO_START=false
AUTONOMY_SUPERVISOR_INTERVAL_MS=30000

# ── S3 / Cloud Storage ──────────────────────────────────────────
S3_BUCKET=
S3_REGION=us-east-1
S3_ACCESS_KEY_ID=
S3_SECRET_ACCESS_KEY=
S3_ENDPOINT=

# ── External Market Data (optional — enriches intelligence) ──────
FINNHUB_API_KEY=
ALPHA_VANTAGE_API_KEY=
TIINGO_API_KEY=
FRED_API_KEY=

# ── CI/CD (GitHub Actions secrets — not in .env) ─────────────────
# DEPLOY_HOST      = your production server IP/hostname
# DEPLOY_USER      = SSH user (e.g. ubuntu)
# DEPLOY_SSH_KEY   = private key content for SSH deploy
# GODSVIEW_IMAGE   = optional override for docker image (default: ghcr.io/santhakumarramesh/godsview:latest)

# ── Python v2 Microservices ───────────────────────────────────────
# Enable Python v2 bridge in Node.js API (set true + start with --profile v2)
PY_SERVICES_ENABLED=false
PY_GATEWAY_URL=http://py-gateway:8000
PYTHON_GATEWAY_URL=http://localhost:8000
PYTHON_SCHEDULER_URL=http://localhost:8008
INTERNAL_API_KEY=internal-dev-key
PROXY_TIMEOUT_MS=10000

# Python service ports
API_GATEWAY_PORT=8000
MARKET_DATA_PORT=8001
FEATURE_PORT=8002
BACKTEST_PORT=8003
ML_PORT=8004
EXECUTION_PORT=8005
RISK_PORT=8006
MEMORY_PORT=8007
SCHEDULER_PORT=8008
TV_BRIDGE_PORT=8009
ORDERFLOW_PORT=8010

# TradingView Bridge
TV_WEBHOOK_SECRET=your-webhook-secret-here
TV_BRIDGE_URL=http://localhost:8009

# TradingView webhook stale-alert gate. Webhook payloads with timestamp older
# than this many seconds are rejected with 400. TradingView fires alerts at
# bar close, so 60s is generous; lower values (10-30s) are stricter for live.
# Set to 0 to disable (development only — never in production).
WEBHOOK_MAX_AGE_SECONDS=60

# Order Flow
ORDERFLOW_URL=http://localhost:8010

# Scheduler
SCAN_INTERVAL_SECONDS=300
RETRAIN_HOUR_UTC=21

# Rate limiting
RATE_LIMIT_PER_MINUTE=60

# Circuit breaker
CB_FAILURE_THRESHOLD=5
CB_RECOVERY_TIMEOUT=30
