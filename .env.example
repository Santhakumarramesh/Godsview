# ─────────────────────────────────────────────────────────────────
# GodsView — Environment Configuration
# Copy to .env and fill in your values
# ─────────────────────────────────────────────────────────────────

# ── Runtime ──────────────────────────────────────────────────────
NODE_ENV=production
PORT=3001

# ── Database ─────────────────────────────────────────────────────
# Docker Compose sets this automatically. Override for external DB.
DATABASE_URL=postgresql://godsview:godsview_secret@postgres:5432/godsview
POSTGRES_PASSWORD=godsview_secret
DB_POOL_MAX=10
DB_EXTERNAL_PORT=5432

# ── Dashboard ────────────────────────────────────────────────────
VITE_API_BASE_URL=http://localhost:3001
CORS_ORIGIN=http://localhost
HTTP_PORT=80

# ── Alpaca Trading API ───────────────────────────────────────────
ALPACA_API_KEY=
ALPACA_SECRET_KEY=
ALPACA_BASE_URL=https://paper-api.alpaca.markets

# ── Claude AI (Veto Layer) ───────────────────────────────────────
ANTHROPIC_API_KEY=
CLAUDE_VETO_MODEL=claude-sonnet-4-5-20241022
CLAUDE_TIMEOUT_MS=30000
CLAUDE_MAX_RETRIES=1

# ── Safety Controls ──────────────────────────────────────────────
GODSVIEW_ENABLE_LIVE_TRADING=false
GODSVIEW_SYSTEM_MODE=live_disabled
GODSVIEW_KILL_SWITCH=false
GODSVIEW_MAX_DAILY_LOSS_USD=250
GODSVIEW_MAX_OPEN_EXPOSURE_PCT=0.6
GODSVIEW_MAX_TRADES_PER_SESSION=10
GODSVIEW_COOLDOWN_AFTER_LOSSES=3
GODSVIEW_COOLDOWN_MINUTES=30
GODSVIEW_BLOCK_ON_DEGRADED_DATA=true

# ── Session Controls ─────────────────────────────────────────────
GODSVIEW_ALLOW_SESSION_ASIAN=true
GODSVIEW_ALLOW_SESSION_LONDON=true
GODSVIEW_ALLOW_SESSION_NY=true
GODSVIEW_NEWS_LOCKOUT_ACTIVE=false

# ── Auth & Security ──────────────────────────────────────────────
GODSVIEW_OPERATOR_TOKEN=change-me

# ── External Data ────────────────────────────────────────────────
ECON_CALENDAR_URL=https://nfs.faireconomy.media/ff_calendar_thisweek.json
